APP_NAME="Cobranzas CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8010

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=cobranzas
DB_USERNAME=cobranzas
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"


VITE_APP_NAME="${APP_NAME}"

# --- Cobranzas CRM ---
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# Integraciones: driver "sandbox" simula todo el ciclo sin credenciales reales
TELEPHONY_DRIVER=sandbox
WHATSAPP_DRIVER=sandbox
LLM_DRIVER=mock   # mock | anthropic | openai

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
TWILIO_VALIDATE_SIGNATURE=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=cobranzas
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=recordings
AWS_ENDPOINT=http://127.0.0.1:9100
AWS_USE_PATH_STYLE_ENDPOINT=true

REVERB_APP_ID=cobranzas
REVERB_APP_KEY=cobranzas-key
REVERB_APP_SECRET=cobranzas-secret
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
BROADCAST_CONNECTION=reverb

CALL_MAX_CONCURRENCY=5
CALL_DAILY_LIMIT=1000
COST_BUDGET_ALERT_PCT=80
